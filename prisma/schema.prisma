// AIRE Intelligence Platform - Prisma Schema
// Database: Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== PHASE 1: Auth + Billing ==============

enum Tier {
  FREE
  PRO
  INVESTOR
}

enum TransactionStatus {
  DRAFT
  ACTIVE
  UNDER_CONTRACT
  PENDING_INSPECTION
  PENDING_APPRAISAL
  PENDING_FINANCING
  CLOSING
  CLOSED
  POST_CLOSE
  CANCELLED
}

model User {
  id              String    @id @default(cuid())
  clerkId         String    @unique
  email           String    @unique
  firstName       String?
  lastName        String?
  tier            Tier      @default(FREE)
  stripeCustomerId String?  @unique
  subscriptionId  String?
  subscriptionStatus String?

  // Onboarding (Day One)
  onboarded               Boolean   @default(false)
  onboardedAt             DateTime?
  onboardingData          Json?
  avatarUrl               String?
  brokerageName           String?
  licenseNumber           String?
  defaultCommissionSplit  Decimal?
  preferredTitleCompany   String?
  signatureData           String?   @db.Text
  voiceProfile            Json?     // extracted writing-style profile for AI reply tone matching

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    Transaction[]
  deadlines       Deadline[]
  voiceCommands   VoiceCommand[]
  documentMemories DocumentMemory[]
  contacts        Contact[]
  relationshipIntelLogs RelationshipIntelLog[]
  morningBriefs   MorningBrief[]
  airSignEnvelopes AirSignEnvelope[]
  emailAccounts   EmailAccount[]
  communicationLogs CommunicationLog[]
  missedCallLogs  MissedCallLog[]
  vendors         Vendor[]
  contentCampaigns ContentCampaign[]
  cmaAnalyses     CMAAnalysis[]
  leadScoreLogs   LeadScoreLog[]
  kpiLogs         KPILog[]
  dealHealthLogs  DealHealthLog[]
  complianceAuditLogs ComplianceAuditLog[]
  pricingAnalysisLogs PricingAnalysisLog[]
  negotiationLogs NegotiationLog[]
  agentRuns       AgentRun[]
  feedbackLogs    FeedbackLog[]
  errorMemories   ErrorMemory[]
  managedSessions ManagedAgentSession[]
  compSets        CompSet[]
  tcsSessions     TCSSession[]
  brokerageMembership BrokerageMember?
}

// ============== PHASE 2: Transaction Core ==============

model Transaction {
  id                String            @id @default(cuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])

  // Property info
  propertyAddress   String
  propertyCity      String            @default("Baton Rouge")
  propertyState     String            @default("LA")
  propertyZip       String?
  propertyType      String?           // residential, commercial, land
  mlsNumber         String?

  // Deal info
  listPrice         Float?
  offerPrice        Float?
  acceptedPrice     Float?
  status            TransactionStatus @default(DRAFT)

  // Parties
  buyerName         String?
  buyerEmail        String?
  buyerPhone        String?
  sellerName        String?
  sellerEmail       String?
  sellerPhone       String?
  lenderName        String?
  titleCompany      String?

  // Key dates
  contractDate      DateTime?
  inspectionDeadline DateTime?
  appraisalDeadline  DateTime?
  financingDeadline  DateTime?
  closingDate        DateTime?

  // Dotloop integration
  dotloopLoopId     String?

  // MLS Paragon Listing Fields
  taxId              String?
  lotNumber          String?
  lotDimensions      String?
  acres              Decimal?
  bedroomCount       Int?
  bathroomsFull      Int?
  bathroomsHalf      Int?
  sqftLiving         Int?
  sqftLower          Int?
  sqftTotal          Int?
  sqftSource         String?   // "APPRAISAL" | "ASSESSMENT" | "MEASURED"
  stories            Int?
  approxAge          String?
  schoolSystem       String?
  subdivision        String?
  yearBuilt          Int?

  // Property Features
  featureCooling     String?
  featureHeating     String?
  featureFoundation  String?
  featureSiding      String?
  featureStyle       String?
  featureParking     String?
  featureUtilGas     String?
  featureUtilElec    String?
  featureWaterSewer  String?
  mineralRights      String?   // "INCLUDED" | "EXCLUDED" | "NEGOTIABLE"

  // Listing metadata
  occupiedBy         String?
  listType           String?
  limitedService     Boolean?
  showingInstructions String?
  mlsSource          String?   // "PARAGON" | "APPRAISAL_EXTRACT" | "OLD_LISTING"
  mlsLastSyncedAt    DateTime?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  deadlines         Deadline[]
  documents         Document[]
  voiceCommands     VoiceCommand[]
  documentMemories  DocumentMemory[]
  workflowEvents    WorkflowEvent[]
  contentCampaigns  ContentCampaign[]
  domProjections    DOMProjection[]
  dealHealthLogs    DealHealthLog[]
  complianceAuditLogs ComplianceAuditLog[]
  negotiationLogs   NegotiationLog[]
  tcsSessions       TCSSession[]

  // Multi-tenant
  brokerageId       String?
  teamId            String?
  assignedTcId      String?

  @@index([userId])
  @@index([brokerageId])
  @@index([teamId])
}

// ============== Workflow Event Log ==============

model WorkflowEvent {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  fromStatus    String?
  toStatus      String
  trigger       String      // "document_uploaded" | "deadline_passed" | "deadline_completed" | "manual" | "voice_command" | "system"
  triggeredBy   String?     // userId or "system"
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([transactionId, createdAt])
}

model Deadline {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id])

  name            String      // e.g., "Inspection Deadline", "Financing Contingency"
  dueDate         DateTime
  alertSent              Boolean     @default(false)
  completedAt            DateTime?
  notes                  String?
  googleCalendarEventId  String?     // GWS: synced Calendar event ID

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId, dueDate])
  @@index([dueDate, alertSent])
}

model Document {
  id              String      @id @default(cuid())
  transactionId   String?
  transaction     Transaction? @relation(fields: [transactionId], references: [id])

  name            String
  type            String      // purchase_agreement, property_disclosure, agency_disclosure, lead_paint, inspection_response, addendum, amendment, disclosure, contract
  category        String?     // mandatory, addendum, federal, broker
  templateId      String?
  filledData      Json?       // AI-extracted field values
  extractedText   String?     // Raw text extracted from PDF
  classification  Json?       // AI classification result with confidence
  fileUrl         String?     // Path or URL to uploaded file
  fileSize        Int?
  pageCount       Int?
  dotloopDocId    String?
  signatureStatus String?     // draft, sent, signed, declined
  checklistStatus String?     // missing, uploaded, extracted, verified
  driveFileId     String?     // GWS: Google Drive file ID after upload
  driveFolderPath String?     // GWS: Drive folder path e.g. "AIRE Transactions/123 Main St"

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([transactionId])
}

// ============== PHASE 3: Document Memory (Self-Improving Classification) ==============

enum DocumentMemoryStatus {
  AUTO_FILED
  NEEDS_REVIEW
  AGENT_CONFIRMED
  AGENT_CORRECTED
  UNKNOWN_TYPE
}

model DocumentMemory {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id])
  transactionId     String?
  transaction       Transaction?         @relation(fields: [transactionId], references: [id])

  // Document fingerprint
  fileHash          String               // SHA-256 of file content
  fileName          String
  fileSize          Int
  pageCount         Int?

  // Classification result
  classifiedType    String
  classifiedConf    Float
  formNumber        String?
  extractionMethod  String?

  // Extracted fields snapshot
  extractedFields   Json?

  // Learning/feedback state
  status            DocumentMemoryStatus @default(AUTO_FILED)
  correctedType     String?
  correctedBy       String?
  correctedAt       DateTime?
  correctionNotes   String?

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([fileHash])
  @@index([classifiedType])
  @@index([status])
  @@index([userId, createdAt])
}

model VoiceCommand {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  transactionId   String?
  transaction     Transaction? @relation(fields: [transactionId], references: [id])

  rawTranscript   String
  parsedIntent    String?
  parsedEntities  Json?
  confidence      Float?
  result          Json?
  status          String       @default("pending") // pending, processing, completed, failed

  createdAt       DateTime     @default(now())
}

// ============== Consensus Engine ==============

model ConsensusLog {
  id           String   @id @default(cuid())
  agentId      String
  feature      String
  prompt       String
  responses    Json
  agreedResult Json?
  confidence   Float
  agreed       Boolean
  createdAt    DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([feature, agreed])
}

// ============== Relationship Intelligence ==============

model Contact {
  id               String    @id @default(cuid())
  agentId          String
  firstName        String
  lastName         String
  email            String?
  phone            String?
  type             String    @default("LEAD")      // LEAD | BUYER | SELLER | PAST_CLIENT | REFERRAL_SOURCE | VENDOR
  source           String?                         // how they came in: zillow | referral | open_house | sign_call | etc
  notes            String?

  // Address / property context
  neighborhood     String?
  parish           String?
  currentAddress   String?
  priceRange       String?                         // "$200K-$300K"
  timeline         String?                         // "60-90 days", "just looking"

  // Relationship tracking
  lastContactedAt  DateTime?
  lastResponseAt   DateTime?
  contactCount     Int       @default(0)
  responseCount    Int       @default(0)
  tags             String[]

  // AI scoring
  relationshipScore Int      @default(50)          // 0-100, updated weekly
  lastScoredAt     DateTime?
  scoreReason      String?

  // Lifecycle
  convertedAt      DateTime?
  transactionId    String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User    @relation(fields: [agentId], references: [id])
  intelLogs        RelationshipIntelLog[]
  leadScoreLogs    LeadScoreLog[]

  @@index([agentId, relationshipScore])
  @@index([agentId, lastContactedAt])
  @@index([agentId, type])
}

// ============== Vendor Management ==============

model Vendor {
  id        String   @id @default(cuid())
  userId    String
  name      String
  company   String?
  category  String   // inspector, appraiser, title, surveyor, pest, other
  phone     String?
  email     String?
  notes     String?
  preferred Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, category])
}

model RelationshipIntelLog {
  id               String   @id @default(cuid())
  agentId          String
  contactId        String
  runDate          DateTime @default(now())

  // Individual agent scores (0-100 each)
  behavioralScore  Int
  lifeEventScore   Int
  marketTimingScore Int
  recencyScore     Int

  // Synthesis
  finalScore       Int
  recommendation   String
  reasoning        String
  suggestedMessage String
  channel          String
  priority         String

  // Consensus metadata
  consensusAgreed  Boolean  @default(false)
  consensusLogId   String?

  createdAt        DateTime @default(now())

  user             User     @relation(fields: [agentId], references: [id])
  contact          Contact  @relation(fields: [contactId], references: [id])

  @@index([agentId, runDate])
  @@index([agentId, finalScore])
}

// ============== Morning Brief ==============

model MorningBrief {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  briefDate       DateTime @db.Date
  status          String   @default("pending") // pending, approved, dismissed

  // Researcher outputs (raw JSON from each researcher)
  deadlineData    Json?
  pipelineData    Json?
  contactData     Json?

  // QA validation
  qaFlags         Json?    // Fair Housing flags, LREC compliance issues
  qaPassedAt      DateTime?

  // Synthesized brief (Claude output)
  summary         String?  // The actual morning brief text
  actionItems     Json?    // Structured action items for UI buttons

  // Human approval gate
  approvedAt      DateTime?
  approvedBy      String?  // clerkId of approver
  dismissedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, briefDate])
  @@index([userId, status])
}

// ============== AirSign ==============

enum EnvelopeStatus {
  DRAFT
  SENT
  IN_PROGRESS
  COMPLETED
  DECLINED
  VOIDED
  EXPIRED
}

enum FieldType {
  SIGNATURE
  INITIALS
  DATE
  TEXT
  CHECKBOX
}

model AirSignEnvelope {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  transactionId   String?

  name            String         // e.g., "Purchase Agreement - 123 Main St"
  status          EnvelopeStatus @default(DRAFT)
  documentUrl     String?        // Vercel Blob URL for the PDF
  pageCount       Int?

  // Delivery
  sentAt          DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  voidedAt        DateTime?
  voidReason      String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  signers         AirSignSigner[]
  fields          AirSignField[]
  auditEvents     AirSignAuditEvent[]

  @@index([userId, status])
  @@index([transactionId])
}

model AirSignSigner {
  id              String         @id @default(cuid())
  envelopeId      String
  envelope        AirSignEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)

  name            String
  email           String
  phone           String?
  role            String         @default("SIGNER") // SIGNER, WITNESS, NOTARY
  order           Int            @default(1)        // signing order
  signingOrder    Int            @default(0)        // sequential signing gate: lowest value signs first

  // Signing state
  token           String         @unique @default(cuid()) // unique link token for /sign/[token]
  tokenExpiresAt  DateTime?      // per-signer token expiration (default +14d on create)
  viewedAt        DateTime?
  signedAt        DateTime?
  declinedAt      DateTime?
  declineReason   String?
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fields          AirSignField[]
  auditEvents     AirSignAuditEvent[]

  @@index([envelopeId])
  @@index([token])
}

model AirSignField {
  id              String         @id @default(cuid())
  envelopeId      String
  envelope        AirSignEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  signerId        String?
  signer          AirSignSigner?  @relation(fields: [signerId], references: [id], onDelete: SetNull)

  type            FieldType      @default(SIGNATURE)
  label           String?
  required        Boolean        @default(true)

  // Position on page (percentage-based for responsiveness)
  page            Int            @default(1)
  xPercent        Float          // 0-100, left edge
  yPercent        Float          // 0-100, top edge
  widthPercent    Float          // 0-100
  heightPercent   Float          // 0-100

  // Value after signing
  value           String?
  filledAt        DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([envelopeId, page])
  @@index([signerId])
}

model AirSignAuditEvent {
  id              String         @id @default(cuid())
  envelopeId      String
  envelope        AirSignEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  signerId        String?
  signer          AirSignSigner?  @relation(fields: [signerId], references: [id], onDelete: SetNull)

  action          String         // created, sent, viewed, signed, declined, voided, completed, resent
  ipAddress       String?
  userAgent       String?
  metadata        Json?

  createdAt       DateTime       @default(now())

  @@index([envelopeId, createdAt])
}

// ============== Email Intelligence ==============

model EmailAccount {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  email        String
  provider     String    // "gmail" | "outlook"
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  tokenExpiry  DateTime?
  isActive     Boolean   @default(true)
  lastScan     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  scans        EmailScan[]

  @@unique([userId, email])
  @@index([userId, isActive])
}

model EmailScan {
  id               String         @id @default(cuid())
  accountId        String
  account          EmailAccount   @relation(fields: [accountId], references: [id])
  scanStart        DateTime       @default(now())
  scanEnd          DateTime?
  emailsScanned    Int            @default(0)
  attachmentsFound Int            @default(0)
  documentsCreated Int            @default(0)
  status           String         @default("running") // running | complete | failed
  error            String?        @db.Text
  createdAt        DateTime       @default(now())

  attachments      EmailAttachment[]

  @@index([accountId, createdAt])
}

model EmailAttachment {
  id           String    @id @default(cuid())
  scanId       String
  scan         EmailScan @relation(fields: [scanId], references: [id])
  emailId      String
  emailSubject String?
  emailFrom    String?
  filename     String
  mimeType     String
  size         Int
  downloaded   Boolean   @default(false)
  classified   Boolean   @default(false)
  documentId   String?
  createdAt    DateTime  @default(now())

  @@index([scanId])
  @@index([emailId])
}

// ============== MONITORING SYSTEM ==============

model AgentActivity {
  id        String   @id @default(cuid())
  agent     String   // "agent-1" | "agent-2" | "agent-3" | "agent-4"
  action    String   // "phase_complete" | "error" | "blocker" | "metric" | "started" | "idle"
  phase     Int?
  message   String   @db.Text
  metadata  Json?
  severity  String   @default("info") // "info" | "warn" | "error" | "critical"
  createdAt DateTime @default(now())

  @@index([agent, createdAt])
  @@index([severity, createdAt])
}

model BuildMetric {
  id        String   @id @default(cuid())
  name      String   // "api_routes" | "type_errors" | "build_time" | "phase_progress"
  value     Float
  agent     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}

// ============== COMMUNICATION MONITOR ==============

model CommunicationLog {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  contactId       String?
  channel         String    // "email" | "sms" | "call"
  direction       String    // "inbound" | "outbound"
  externalId      String?   // Gmail message ID, Twilio SID, etc.
  threadId        String?   // Gmail thread ID for grouping
  fromAddress     String    // email, phone number
  toAddress       String
  subject         String?
  bodyPreview     String?   @db.Text
  sentAt          DateTime
  status          String    @default("delivered") // "delivered" | "read" | "replied" | "missed" | "unanswered"
  respondedAt     DateTime?
  responseLogId   String?   // ID of the reply CommunicationLog
  draftReply      String?   @db.Text
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@unique([externalId])
  @@index([userId, status, sentAt])
  @@index([userId, contactId, sentAt])
  @@index([threadId])
  @@index([userId, channel, direction, sentAt])
}

model MissedCallLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  callerPhone String
  callerName  String?
  contactId   String?
  callTime    DateTime
  duration    Int      @default(0) // seconds, 0 = missed
  returned    Boolean  @default(false)
  returnedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, returned, callTime])
}

// ============== Agent 5: Content Engine ==============

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  REJECTED
}

model ContentCampaign {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  transactionId    String?
  transaction      Transaction?  @relation(fields: [transactionId], references: [id])
  propertyAddress  String?
  mlsNumber        String?

  // Multi-format content
  mlsDescription   String?       @db.Text
  instagramCaption String?       @db.Text
  facebookPost     String?       @db.Text
  linkedinPost     String?       @db.Text
  emailTemplate    String?       @db.Text
  smsTemplate      String?

  // Approval workflow
  status           ContentStatus @default(DRAFT)
  fairHousingCheck Json?         // { passed: bool, warnings: string[] }
  submittedAt      DateTime?
  approvedAt       DateTime?

  // Scheduling
  scheduledFor     DateTime?
  publishedAt      DateTime?
  calendarDays     Json?         // 30-day posting schedule

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId, status])
  @@index([transactionId])
}

// ============== Agent 6: Intelligence Engine ==============

model CMAAnalysis {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  transactionId    String?
  propertyAddress  String

  selectedComps    Json?    // [{ address, price, soldDate, adjustments }]
  cmaEstimate      Float?
  confidence       Float?   // 0-1
  adjustments      Json?    // [{ factor: "pool", amount: 15000 }]

  bpsScore         Float?   // Buyer Perception Score
  ppsScore         Float?   // Pricing Position Score
  uriScore         Float?   // Unknown Repair Index

  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([propertyAddress])
}

model LeadScoreLog {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id])
  contactId             String
  contact               Contact  @relation(fields: [contactId], references: [id])

  communicationFrequency Float
  lifeEventSignals       Float
  marketTiming           Float
  recencyWarmth          Float
  finalScore             Float
  recommendation         String   // "high" | "warm" | "cool" | "dormant"

  createdAt              DateTime @default(now())

  @@index([userId, createdAt])
  @@index([contactId])
}

model DOMProjection {
  id               String   @id @default(cuid())
  transactionId    String
  transaction      Transaction @relation(fields: [transactionId], references: [id])

  listPrice        Float
  projectedDOM30   Int?
  projectedDOM60   Int?
  projectedDOM90   Int?

  netProceeds30    Float?
  netProceeds60    Float?
  netProceeds90    Float?

  createdAt        DateTime @default(now())

  @@index([transactionId])
}

model KPILog {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  period              String   // "2026-03" (month), "2026-Q1" (quarter), "2026" (year)

  closedTransactions  Int      @default(0)
  avgDaysToClose      Float?
  totalCommission     Float?
  avgCommission       Float?
  pipelineValue       Float?
  activeDeals         Int      @default(0)

  createdAt           DateTime @default(now())

  @@unique([userId, period])
}

// ============== Team 2: Deal Rescue ==============

model DealHealthLog {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  transactionId     String
  transaction       Transaction @relation(fields: [transactionId], references: [id])

  timelineScore     Float       // 0-10
  communicationScore Float      // 0-10
  documentScore     Float       // 0-10
  sentimentScore    Float       // 0-10
  finalHealthScore  Float       // weighted average 1-10

  recommendation    String      // "critical" | "at_risk" | "healthy" | "closing"
  rescueBrief       String?     @db.Text  // AI-generated action plan
  runDate           DateTime    @default(now())

  @@index([userId, runDate])
  @@index([transactionId])
  @@index([finalHealthScore])
}

// ============== Team 3: LREC Guardian ==============

model ComplianceAuditLog {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  transactionId     String
  transaction       Transaction @relation(fields: [transactionId], references: [id])

  documentCheck     Json        // { category, required, present, missing[] }
  deadlineCheck     Json        // { name, dueDate, completed, overdue }
  disclosureCheck   Json        // { type, signed, signerName, signedDate }

  finalStatus       String      // "green" | "yellow" | "red"
  blockers          String[]    // exact items preventing submission
  runDate           DateTime    @default(now())

  @@index([userId, runDate])
  @@index([transactionId])
}

// ============== Team 4: Seller Pricing War Room ==============

model PricingAnalysisLog {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  contactId         String?
  propertyAddress   String

  cmaEstimate       Float?
  zillowestimate    Float?
  avmGapPct         Float?   // gap between Zillow and CMA

  conservativePrice Float?
  targetPrice       Float?
  aggressivePrice   Float?
  recommendedPrice  Float?

  domProjection30   Int?
  domProjection60   Int?
  domProjection90   Int?

  objections        Json?    // [{ objection, response }]
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

// ============== Team 6: Negotiation Intelligence ==============

model NegotiationLog {
  id                   String      @id @default(cuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id])
  transactionId        String
  transaction          Transaction @relation(fields: [transactionId], references: [id])

  incomingOfferPrice   Float?
  incomingTerms        Json?       // { earnestMoney, inspectionDays, financingDays, closingDate }
  marketAnalysis       Json?       // { cmaEstimate, competitive, fairness }
  sellerMotivation     String?     // "flexible" | "firm" | "desperate" | "time_constrained"

  // Recommendations
  recommendedAction    String?     // "accept" | "counter" | "reject"
  recommendedCounter   Float?
  acceptanceProbability Float?     // 0-1
  expectedClosingDays  Int?
  expectedNetProceeds  Float?

  scenarios            Json?       // [{ action, price, probability, netProceeds }]
  createdAt            DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([transactionId])
}

// ============== Agent Infrastructure ==============

model AgentRun {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id])
  agentName      String    // "morning_brief", "deal_rescue", "email_scan", etc.
  status         String    @default("running") // "running" | "success" | "failed"
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  error          String?
  resultMetadata Json?

  @@index([agentName, startedAt])
  @@index([userId, agentName])
}

// ============== Self-Learning Engine ==============

model FeedbackLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  feature     String   // "morning_brief" | "voice" | "contract" | "compliance" | "document" | "email"
  rating      Int?     // 1 (thumbs down) or 5 (thumbs up)
  inputHash   String?  // hash of the AI input
  outputHash  String?  // hash of the AI output
  correction  Json?    // { field: "buyerName", before: "John", after: "Jonathan" }
  dismissed   Boolean  @default(false) // user dismissed a suggestion/alert
  metadata    Json?    // extra context
  createdAt   DateTime @default(now())

  @@index([userId, feature, createdAt])
  @@index([feature, rating])
  @@index([feature, dismissed])
}

model ErrorMemory {
  id           String   @id @default(cuid())
  agentName    String   // "morning_brief" | "voice" | "content" | etc.
  errorType    String   // "transient" | "permanent" | "data_quality" | "prompt_failure"
  errorMessage String
  input        Json?    // what was sent to the AI
  output       Json?    // what came back (if anything)
  context      Json?    // extra context (userId, transactionId, etc.)
  occurrences  Int      @default(1) // how many times this exact error has happened
  lastSeenAt   DateTime @default(now())
  resolved     Boolean  @default(false)
  resolvedAt   DateTime?
  resolution   String?  // what fixed it
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([agentName, errorType, resolved])
  @@index([agentName, createdAt])
  @@index([errorMessage])
}

model PromptVersion {
  id          String   @id @default(cuid())
  agentName   String   // "voice_classifier" | "contract_writer" | "morning_brief" | etc.
  version     Int
  promptText  String   @db.Text
  metrics     Json?    // { successRate: 0.92, avgRating: 4.1, errorRate: 0.03, sampleSize: 150 }
  active      Boolean  @default(true)
  notes       String?  // what changed from previous version
  createdAt   DateTime @default(now())

  @@unique([agentName, version])
  @@index([agentName, active])
}

// ============== Managed Agent Sessions ==============

model ManagedAgentSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  agentName   String   // "morning_brief" | "deal_rescue" | "learning"
  sessionId   String   @unique // Anthropic managed agent session ID
  status      String   @default("active") // "active" | "expired" | "cancelled"
  expiresAt   DateTime
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, agentName, status])
}

// ============== CMA Engine ==============

model CompSet {
  id                       String   @id @default(cuid())
  userId                   String
  user                     User     @relation(fields: [userId], references: [id])

  subjectAddress           String
  subjectPropertyId        String?
  subjectLat               Float?
  subjectLng               Float?
  subjectSqft              Int?
  subjectBeds              Int?
  subjectBaths             Float?
  subjectYearBuilt         Int?
  subjectLotSize           Int?
  subjectCondition         String?  // 'excellent' | 'good' | 'average' | 'fair' | 'poor'
  subjectFeatures          Json?    // { pool, garage_bays, fireplace, waterfront, ... }

  mlsSuggestedPrice        Float?
  propstreamSuggestedPrice Float?
  rprSuggestedPrice        Float?

  aireEstimate             Float?
  aireRangeLow             Float?
  aireRangeHigh            Float?
  confidenceTier           String?  // HIGH | MEDIUM | LOW
  confidenceScore          Float?   // 0-1
  disagreementPct          Float?

  vendorsResponded         Int      @default(0) // 0-3
  degradationBand          String   @default("full") // full | partial | degraded
  excludedFromTraining     Boolean  @default(false)

  mortgageContext          Json?
  status                   String   @default("active") // active | listed | sold | abandoned | degraded

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  comps                    Comp[]
  accuracyLog              AccuracyLog?

  @@index([userId, createdAt])
  @@index([subjectAddress])
  @@index([status])
}

model Comp {
  id                 String   @id @default(cuid())
  compSetId          String
  compSet            CompSet  @relation(fields: [compSetId], references: [id], onDelete: Cascade)

  source             String   // 'mls_paragon' | 'propstream' | 'rpr'
  address            String
  lat                Float?
  lng                Float?

  soldPrice          Float
  soldDate           DateTime
  listPrice          Float?
  daysOnMarket       Int?

  sqft               Int?
  beds               Int?
  baths              Float?
  yearBuilt          Int?
  lotSize            Int?
  garageBays         Int?
  condition          String?
  features           Json?
  distanceMiles      Float?

  similarityScore    Float    @default(0) // 0-1
  selected           Boolean  @default(false)
  adjustments        Json?    // [{ factor, amount, reason }]
  adjustedValue      Float?
  weight             Float?
  overAdjusted       Boolean  @default(false)

  rawPayload         Json?    // normalized vendor payload (no HTML)

  createdAt          DateTime @default(now())

  @@index([compSetId, selected])
  @@index([source])
  @@index([soldDate])
}

model AccuracyLog {
  id                    String   @id @default(cuid())
  compSetId             String   @unique
  compSet               CompSet  @relation(fields: [compSetId], references: [id], onDelete: Cascade)

  actualListPrice       Float?
  actualSoldPrice       Float?
  actualDOM             Int?
  actualSoldDate        DateTime?

  mlsError              Float?   // (mlsSuggested - soldPrice) / soldPrice
  propstreamError       Float?
  rprError              Float?
  aireError             Float?

  winner                String?  // 'mls' | 'propstream' | 'rpr' | 'aire'
  notes                 String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([createdAt])
  @@index([winner])
}

model ScraperSession {
  id               String   @id @default(cuid())
  vendor           String   @unique // 'mls_paragon' | 'propstream' | 'rpr'
  storagePath      String
  lastLoginAt      DateTime
  lastProbeAt      DateTime?
  status           String   @default("healthy") // 'healthy' | 'expired' | 'locked'
  ttlMinutes       Int      @default(60)
  failureCount     Int      @default(0)
  circuitOpenUntil DateTime?
  notes            String?
  updatedAt        DateTime @updatedAt
}

// ============== PHASE 8: TCS (Transaction Coordination System) ==============

model TCSSession {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  transactionId   String?
  transaction     Transaction?      @relation(fields: [transactionId], references: [id])

  side            String            // "BUYER" | "LISTING" | "DUAL"
  currentStage    TransactionStatus @default(DRAFT)
  messages        Json              @default("[]")
  answers         Json              @default("{}")
  silentActions   Json              @default("[]")

  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([transactionId])
}

model TCSQuestion {
  id             String             @id @default(cuid())
  stage          TransactionStatus
  key            String             @unique
  promptTemplate String             @db.Text
  quickReplies   Json?
  required       Boolean            @default(true)
  orderHint      Int                @default(0)
  createdAt      DateTime           @default(now())

  @@index([stage, orderHint])
}

// ============== PHASE 9: Broker-Tenant Model ==============

model Brokerage {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  logoUrl        String?
  primaryContact String?
  billingEmail   String?
  seatCount      Int       @default(1)
  tier           String    @default("STANDARD") // "STANDARD" | "ENTERPRISE"

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members        BrokerageMember[]
  teams          Team[]
}

model BrokerageMember {
  id            String    @id @default(cuid())
  brokerageId   String
  brokerage     Brokerage @relation(fields: [brokerageId], references: [id])
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  role          String    // "OWNER" | "BROKER" | "TC" | "AGENT" | "ASSISTANT"
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  joinedAt      DateTime  @default(now())

  @@index([brokerageId])
}

model Team {
  id            String    @id @default(cuid())
  brokerageId   String
  brokerage     Brokerage @relation(fields: [brokerageId], references: [id])
  name          String
  leaderUserId  String?

  members       BrokerageMember[]

  @@index([brokerageId])
}
